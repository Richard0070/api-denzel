{
  "version": 2,
  "builds": [
    {
      "src": "api/main.py",
      "use": "@vercel/python",
      "config": {
        "runtime": "python3.8"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/main.py"
    }
  ],
  "build": {
    "env": {
      "PYTHON_VERSION": "3.8"
    },
    "cmd": "sh setup.sh"
  }
}
